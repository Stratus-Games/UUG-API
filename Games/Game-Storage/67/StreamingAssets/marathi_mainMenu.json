},{
	"key": "rebelE1",
	"value": "आपण वरील लढाई जिंकू शकाल कारण (50+50)> (20 + 20)."
},{
	"key": "localE",
	"value": "एखाद्या देशावर विजय मिळवल्यानंतर, शत्रू सैन्य आपल्या स्थानिक सैन्यात बदलते.आपण त्यावर नियंत्रण ठेवा.त्यांची शक्ती वाढविण्यासाठी त्यांच्यावर क्लिक करा.ते आपल्या जिंकलेल्या देशाचे बंडखोर हल्ल्यापासून किंवा परकीय हल्ल्यापासून संरक्षण करतील.स्क्रीनच्या वरील उजव्या कोपर्यात एक संदेश बटण आपल्याला हल्ल्यांबद्दल माहिती देईल."
},{
	"key": "localD1",
	"value": "(आपल्या जिंकलेल्या देशातील स्थानिक सैन्य.)"
},{
	"key": "foreignD1",
	"value": "(विदेशी हल्ला)"
},{
	"key": "foreignE1",
	"value": "एकदा आपण एखाद्या देशावर विजय मिळविला की, परदेशी देशाने त्याच्यावर आक्रमण केले जाऊ शकते.स्क्रीनच्या वरील उजव्या कोपर्यात एक संदेश बटण आपल्याला हल्ल्यांबद्दल माहिती देईल.हल्ल्यापासून बचाव करण्यासाठी आपली स्थानिक लष्करी सैन्ये वाढवा.जर आपण हल्ल्यात हरवला तर आपण त्या देशातील सर्व उत्पादन क्रिया गमावाल आणि आपल्याला पुन्हा तो देश जिंकून द्यावा लागेल."
},{
